{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "installCommand": "bun install",
  "framework": null,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/pitch", "destination": "/pitch/index.html" },
    { "source": "/pitch/(.*)", "destination": "/pitch/index.html" },
    { "source": "/((?!pitch|assets|shots|slice-logo|_redirects|404).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/pitch/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
